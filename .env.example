# Environment Variables for AI Chatbot Integration
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (required for AI chat and document analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative AI providers (optional)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# Django Settings
DEBUG=True
SECRET_KEY=your-django-secret-key-here

# Database (SQLite is default, can be changed to PostgreSQL/MySQL)
DATABASE_URL=sqlite:///db.sqlite3

# Media files
MEDIA_ROOT=media/
MEDIA_URL=/media/

# File upload settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_UPLOAD_TYPES=application/pdf,image/jpeg,image/jpg,image/png,image/gif